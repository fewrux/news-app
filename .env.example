# Copy to `.env.local` (or `.env`) and fill in real values.
# Never commit real secrets. CI reads these from GitHub Action Secrets.

# --- LangSmith (already configured in .env) ---
TRACE_TO_LANGSMITH=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=news-app

# --- PostHog (free tier) -------------------------------------------------
# Public, browser-exposed. Project API key, NOT a personal API key.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Personal API key — server-side only, used by scripts that read PostHog data.
POSTHOG_PERSONAL_API_KEY=

# --- Vercel (free Hobby plan) -------------------------------------------
# Used by GitHub Actions to deploy. Generate from vercel.com/account/tokens.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Plane (free cloud or self-hosted) ----------------------------------
PLANE_API_BASE=https://api.plane.so
PLANE_API_TOKEN=
PLANE_WORKSPACE_SLUG=
PLANE_PROJECT_ID=

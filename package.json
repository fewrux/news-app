{
  "name": "news-app",
  "version": "0.1.0",
  "private": true,
  "description": "news-app (The Daily Brief) — AI-native SDLC sandbox. Read AGENTS.md first; the contract is .sdlc/sdlc.yaml.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:verify": "playwright test --config playwright.verify.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "gate:phase": "node scripts/check-phase-exit.mjs",
    "plane:sync": "node scripts/plane-sync.mjs",
    "plane:sync:docs": "node scripts/plane-sync.mjs sync-docs docs",
    "doctor": "node scripts/sdlc-doctor.mjs --mode=mechanical",
    "doctor:eval": "node scripts/doctor-eval.mjs"
  },
  "dependencies": {
    "next": "16.2.6",
    "posthog-js": "^1.376.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

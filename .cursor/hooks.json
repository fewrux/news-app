{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/load-context.mjs",
        "timeout": 5
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/scan-secrets.mjs",
        "timeout": 5,
        "failClosed": true
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/guard-shell.mjs",
        "timeout": 5,
        "failClosed": true
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/lint-touch.mjs",
        "timeout": 5
      }
    ]
  }
}
